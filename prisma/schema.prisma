generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  CONTRIBUTOR
  ADMIN
}

enum Tier {
  FREE
  PRO
}

enum ResourceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResourceType {
  LINK
  PDF
  ARTICLE
  VIDEO
}

enum VoteType {
  UP
  DOWN
}

// ─── NextAuth Required Models ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?   @db.Text
  role          Role      @default(USER)
  tier          Tier      @default(FREE)
  interests     String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  resources     Resource[]
  votes         Vote[]
  comments      Comment[]
  bookmarks     Bookmark[]
  flags         Flag[]
  activityLogs  ActivityLog[]
  weeklyDigests WeeklyDigest[]
  subscription  Subscription?
}

model Resource {
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  url          String?
  fileUrl      String?
  type         ResourceType
  status       ResourceStatus @default(PENDING)
  summary      String?        @db.Text
  qualityScore Int?
  viewCount    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  authorId     String
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tags         TagOnResource[]
  votes        Vote[]
  comments     Comment[]
  bookmarks    Bookmark[]
  flags        Flag[]

  @@index([authorId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Tag {
  id        String          @id @default(cuid())
  name      String          @unique
  color     String?
  createdAt DateTime        @default(now())
  resources TagOnResource[]
}

model TagOnResource {
  id         String   @id @default(cuid())
  resourceId String
  tagId      String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([resourceId, tagId])
  @@index([tagId])
}

model Vote {
  id         String   @id @default(cuid())
  type       VoteType
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  userId     String
  resourceId String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([resourceId])
  @@index([parentId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
}

model Flag {
  id         String   @id @default(cuid())
  reason     String   @db.Text
  userId     String
  resourceId String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resolved])
}

model Subscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  razorpayCustomerId     String?   @unique
  razorpaySubscriptionId String?   @unique
  razorpayPlanId         String?
  currentPeriodEnd       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?  @db.Text
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model WeeklyDigest {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
